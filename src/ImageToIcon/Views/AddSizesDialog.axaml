<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:ImageToIcon.Models"
        x:Class="ImageToIcon.Views.AddSizesDialog"
        Title="Add Sizes"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Window.Styles>
        <Style Selector="ToggleButton.cell">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style Selector="ToggleButton.pill">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}" />
        </Style>
        <Style Selector="NumericUpDown TextBox">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="SelectionForegroundBrush" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style Selector="NumericUpDown TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="NumericUpDown TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="NumericUpDown TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ButtonSpinner">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <DataValidationErrors>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid ColumnDefinitions="*,Auto">
                                <ContentPresenter Name="PART_ContentPresenter"
                                                  Grid.Column="0"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Padding="{TemplateBinding Padding}"
                                                  ClipToBounds="True"
                                                  VerticalContentAlignment="Center" />
                                <Grid Grid.Column="1" RowDefinitions="*,*" Width="14">
                                    <RepeatButton Name="PART_IncreaseButton"
                                                  Grid.Row="0"
                                                  Classes="spinnerbtn">
                                        <Path Data="M 0,4 L 4,0 L 8,4 Z"
                                              Fill="{DynamicResource AppSubTextBrush}"
                                              Width="8" Height="4" />
                                    </RepeatButton>
                                    <RepeatButton Name="PART_DecreaseButton"
                                                  Grid.Row="1"
                                                  Classes="spinnerbtn">
                                        <Path Data="M 0,0 L 4,4 L 8,0 Z"
                                              Fill="{DynamicResource AppSubTextBrush}"
                                              Width="8" Height="4" />
                                    </RepeatButton>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataValidationErrors>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RepeatButton.spinnerbtn">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="RepeatButton.spinnerbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="RepeatButton.spinnerbtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="RepeatButton.spinnerbtn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="RepeatButton.spinnerbtn:disabled Path">
            <Setter Property="Opacity" Value="0.35" />
        </Style>
    </Window.Styles>

    <StackPanel Margin="16" Spacing="8">

        <TextBlock Text="DPI scaling  (rows: base size · columns: scale):" FontSize="12" />
        <Grid>
            <Grid x:Name="DpiGrid" />
            <Button x:Name="SelectAllBtn" Content="Select all"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    ClipToBounds="False">
                <Button.RenderTransform>
                    <TranslateTransform Y="40" />
                </Button.RenderTransform>
            </Button>
        </Grid>

        <TextBlock Text="Replacements for the top frame:" FontSize="11" Margin="0,8,0,0" />
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="256" FontSize="12" FontWeight="Bold" Opacity="0.5"
                       FontFamily="{StaticResource AppMonoFontFamily}"
                       VerticalAlignment="Center" Margin="4,0,8,0" />
            <ItemsControl x:Name="HighResItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:SizeCellVm">
                        <ToggleButton Classes="cell"
                                      Content="{Binding SizeText}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      IsEnabled="{Binding !IsReserved}"
                                      ToolTip.Tip="{Binding Tooltip}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <TextBlock Text="Custom size:" FontSize="11" Margin="0,8,0,0" />
        <WrapPanel x:Name="CustomRow" Orientation="Horizontal">
            <NumericUpDown x:Name="CustomInput" Value="128"
                           Increment="2" FormatString="0" Width="72"
                           ClipValueToMinMax="True"
                           VerticalAlignment="Stretch"
                           VerticalContentAlignment="Center"
                           MinHeight="0"
                           Margin="0,0,6,0" />
            <Button x:Name="AddCustomBtn" Content="Add"
                    HorizontalContentAlignment="Center" Margin="0,0,6,0" />
            <TextBlock x:Name="CustomError" FontSize="12" Foreground="OrangeRed"
                       VerticalAlignment="Center" IsVisible="False" />
        </WrapPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="OkBtn" Content="OK" Width="80" IsDefault="True"
                    HorizontalContentAlignment="Center" />
            <Button x:Name="CancelBtn" Content="Cancel" Width="80" IsCancel="True"
                    HorizontalContentAlignment="Center" />
        </StackPanel>

    </StackPanel>
</Window>
