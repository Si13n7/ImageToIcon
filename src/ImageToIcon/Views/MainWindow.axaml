<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:m="using:ImageToIcon.Models"
        mc:Ignorable="d"
        x:Class="ImageToIcon.Views.MainWindow"
        Title="Image To Icon"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        Icon="/Assets/ProgramIcon.ico"
        Background="{DynamicResource AppWindowBrush}"
        Foreground="{DynamicResource AppTextBrush}"
        DragDrop.AllowDrop="True">

    <Window.Styles>
        <Style Selector="ToggleButton.pill">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ToggleButton.pill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppThumbBorderBrush}" />
        </Style>
        <Style Selector="ToggleButton.pill:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppThumbBorderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppThumbBorderBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.pill:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppThumbBorderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppThumbBorderBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.pill.unavailable">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="ToggleButton.iconbtn">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ToggleButton.iconbtn:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
        </Style>
        <Style Selector="ToggleButton.iconbtn:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrushPointerOver}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundPointerOver}" />
        </Style>
        <Style Selector="ToggleButton.iconbtn:checked:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPressed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrushPressed}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundPressed}" />
        </Style>
        <Style Selector="Button.pill">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.pill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppThumbBorderBrush}" />
        </Style>
    </Window.Styles>

    <Window.Resources>
        <DataTemplate x:Key="ThumbTemplate" DataType="m:IconThumb">
            <StackPanel Margin="2" Spacing="2"
                        ToolTip.Tip="{Binding TooltipText}"
                        Cursor="Hand"
                        Tag="{Binding}"
                        Background="Transparent"
                        PointerPressed="Thumb_PointerPressed"
                        DragDrop.AllowDrop="True">
                <Grid Width="{Binding DisplaySize}" Height="{Binding DisplaySize}">
                    <Image Source="{Binding Preview}" Stretch="Fill" />
                    <Rectangle Stroke="{DynamicResource AppThumbBorderBrush}"
                               StrokeThickness="1"
                               StrokeDashArray="2,2"
                               IsHitTestVisible="False"
                               IsVisible="{Binding #BorderToggle.IsChecked}" />
                </Grid>
                <TextBlock Text="{Binding SizeLabel}"
                           Foreground="{DynamicResource AppThumbBorderBrush}"
                           FontFamily="Calibri" FontWeight="Bold" FontSize="10"
                           HorizontalAlignment="Right"
                           IsHitTestVisible="False" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid RowDefinitions="*,Auto">

        <Border Grid.Row="0" Padding="8" Background="{DynamicResource AppCategoryBrush}">
            <Grid RowDefinitions="*,Auto">
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Center">
                        <ItemsControl x:Name="TopThumbs"
                                      ItemTemplate="{StaticResource ThumbTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl x:Name="SmallThumbs"
                                      ItemTemplate="{StaticResource ThumbTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
                <ToggleButton x:Name="BorderToggle" Grid.Row="1" Classes="iconbtn" IsChecked="True"
                              HorizontalAlignment="Left" Margin="0,4,0,0"
                              ToolTip.Tip="Toggle thumb borders">
                    <Rectangle Width="12" Height="12"
                               Stroke="{DynamicResource ButtonForeground}"
                               StrokeThickness="1"
                               StrokeDashArray="2,2"
                               Opacity="0.65" />
                </ToggleButton>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Stretch"
                    Spacing="12" Margin="8,14">
            <ItemsControl x:Name="SizeToggles" HorizontalAlignment="Center" MaxWidth="720">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:SizeToggle">
                        <ToggleButton Classes="pill" Margin="2"
                                      Classes.unavailable="{Binding !IsAvailable}"
                                      Content="{Binding Label}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button x:Name="AddSizeBtn" Classes="pill" Content="+ Add sizes"
                    HorizontalAlignment="Center"
                    ToolTip.Tip="Add sizes" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Button x:Name="UpdateBtn" Width="120" IsVisible="False"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="{DynamicResource AppUpdateBrush}"
                        Foreground="Black" />
                <Button x:Name="OpenBtn" Content="Open Image" Width="120"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                <Button x:Name="SaveBtn" Content="Save Icon" Width="120"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>